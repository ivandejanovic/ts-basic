{
	"name": "nodebasic",
	"subdomain": "nodebasic",
	"description": "Example basic node setup",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/ivandejanovic/ts-basic.git"
	},
	"main": "src/index.js",
	"scripts": {
		"start": "node build/src/index.js",
		"tsc": "tsc -p tsconfig.json",
		"dev": "ts-node-dev --respawn --transpileOnly ./server/src/index.ts",
		"prod": "tsc -p tsconfig.json && node ./build/src/index.js"
	},
	"dependencies": {
		"axios": "^1.15.0",
		"morgan": "^1.10.1",
		"method-override": "^3.0.0",
		"body-parser": "^2.2.2",
		"errorhandler": "^1.5.2",
		"express": "^5.2.1",
		"pug": "^3.0.4",
		"path": "^0.12.7"
	},
	"devDependencies": {
		"@types/express": "^5.0.6",
		"@types/errorhandler": "^1.5.3",
		"@types/method-override": "^3.0.0",
		"@types/morgan": "^1.9.9",
		"@types/node": "^25.6.0",
		"ts-node-dev": "^2.0.0",
		"tslint": "^5.20.1",
		"tslint-config-prettier": "^1.18.0",
		"typescript": "^6.0.2"
	},
	"version": "1.0.0",
	"engines": {
		"node": "^22.x.x"
	}
}